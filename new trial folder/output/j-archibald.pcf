	<ouc:properties label="config">
		<parameter section="Hero Content" group="" type="select" name="hero-background" prompt="Background Color" alt="Select the background color to be used for the hero section.">
			<option value="red" selected="true">Red</option>
			<option value="gray" selected="false">Gray</option>
		</parameter>

		<parameter section="Show/Hide Header Fields" name="show-title" group="Everyone" type="select" prompt="Title" alt="Default will show the title unless it is hidden by the _props.pcf or a directory variable. Show or Hide will override a value set elsewhere.">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>
		<parameter name="show-department" group="Everyone" type="select" prompt="Department" alt="Default will show the department unless it is hidden by the _props.pcf or a directory variable. Show or Hide will override a value set elsewhere">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>
		<parameter name="show-program" group="Everyone" type="select" prompt="Program Area" alt="Default will show the program unless it is hidden by the _props.pcf or a directory variable. Show or Hide will override a value set elsewhere">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>
		<parameter name="show-unit" group="Everyone" type="select" prompt="Organizational Unit" alt="Default will show the unit unless it is hidden by the _props.pcf or a directory variable. Show or Hide iwill override a value set elsewhere">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>
		<parameter name="show-division" group="Everyone" type="select" prompt="Division" alt="Default will show the division unless it is hidden by the _props.pcf or a directory variable. Show or Hide implies override.">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>
		<parameter name="show-region" group="Everyone" type="select" prompt="Location: Region" alt="Default will show the region unless it is hidden by the _props.pcf or a directory variable. Show or Hide implies override. (Region may be listed as Campus on some sites.)">
			<option value="" selected="true">Default</option>
			<option value="true" selected="false">Show</option>
			<option value="false" selected="false">Hide</option>
		</parameter>

		<parameter section="Editable Regions" group="Everyone" type="checkbox" name="content-regions" prompt="Editable Region" alt="Turn on/off content elements to customize the layout.">
