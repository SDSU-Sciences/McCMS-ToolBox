	<ouc:properties label="pre-footer">
		<parameter section="Pre-Footer" name="pre-footer" type="checkbox" group="Everyone" prompt="Display" alt="Check to display the global pre-footer.The pre-footer will be dislayed above the footer.">
			<option value="yes" selected="false">Yes</option>
		</parameter>
	</ouc:properties>

	<ouc:properties label="meta-tags">
		<parameter section="Social Meta Tags" name="override-og-type" type="text" group="Everyone" prompt="Og Type" alt="Please enter the open graph type. Enter 'website' unless you can provide the required fields for other types."></parameter>
		<parameter name="override-og-image" type="filechooser" group="Everyone" prompt="Og Image" alt="Please choose the open graph image." dependency="yes"></parameter>
		<parameter name="override-og-image-alt" type="text" group="Everyone" prompt="Og Image Alt" alt="Please enter the open graph image alt text."></parameter>
		<parameter name="override-og-description" type="textarea" group="Everyone" prompt="Og Description" alt="Please enter the open graph description." rows="7"></parameter>
		<parameter name="override-twitter-card-description" type="text" group="Everyone" prompt="Twitter Card Description" alt="Please enter the twitter card description. This description will trimmed at 200 characters per Twitter Documentation."></parameter>
		<parameter name="override-twitter-card-image" type="filechooser" group="Everyone" prompt="Twitter Card Image" alt="Please choose the twitter card image. This image size needs to be below 5MB in size per Twitter Documentation." dependency="yes"></parameter>
		<parameter name="override-twitter-card-image-alt" type="text" group="Everyone" prompt="Twitter Card Image Alt" alt="Please enter the twitter card image alt text. This alt text will be trimmed at a length of 420 characters per Twitter Documentation."></parameter>
		<parameter name="override-twitter-card-type" type="select" group="Everyone" prompt="Twitter Card Type" alt="Please choose the twitter card type.">
			<option value="summary" selected="false">Summary</option>
			<option value="summary_large_image" selected="true">Summary Large Image</option>
		</parameter>
	</ouc:properties>

	<ouc:properties label="seo-config">
		<parameter section="Search Engine Optimization" name="robots" type="checkbox" group="sciences site-admin" prompt="Prevent Search Indexing" alt="Prevent this page from being listed by search engines. Note: if the page is already listed, it may take some time to be removed using this method.">
			<option value="noindex" selected="false">Do Not Show in Search Results</option>
		</parameter>
	</ouc:properties>

	<parameter name="dsn">faculty</parameter>
	<parameter name="page-type">wysiwyg</parameter>

	<item>
		<ouc:div label="prefix" group="Everyone" button="hide"><ouc:multiedit section="Personal Info" type="text" prompt="Prefix" alt="Prefix or abbreviated title (e.g. Mx., Prof., or Mrs.)." /></ouc:div>
		<ouc:div label="first-name" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="First Name" />J.</ouc:div>
		<ouc:div label="last-name" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="Last Name" />Archibald</ouc:div>
		<ouc:div label="suffix" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="Suffix" />Ph.D.</ouc:div>
		<ouc:div label="display-name" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="Display Name" alt="If provided, overrides Prefix, First Name, Last Name, and Suffix for display purposes. First and Last Name fields will still be used for sorting purposes on the list." />J. David Archibald</ouc:div>
		<ouc:div label="pronouns" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="Pronouns" alt="Enter preferred personal pronouns (ie. They/Them)." />David</ouc:div>
		<ouc:div label="sort-order" group="Everyone" button="hide"><ouc:multiedit type="text" prompt="Sort Order" alt="Numeric value to override alphabetic sorting (Optional), e.g. to place the Dean at the top of the list, enter '1', or to push someone to the bottom of the list, enter a value &amp;gt; 1000." /></ouc:div>

		<ouc:div label="image" group="Everyone" button="hide"><ouc:multiedit type="image" prompt="Image" alt="Select a profile photo. Use a square image that is at least 300x300 pixels." path="/images/faculty" lockout="no"/><img src="https://biology.sdsu.edu/wp-content/uploads/profiles/david-archibald-300.jpg" alt="Closeup of silhouette" /></ouc:div>

